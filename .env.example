# PostgreSQL 连接字符串
# 本地开发示例：postgresql://user:password@localhost:5432/attendance?schema=public
# Neon 示例：postgresql://user:password@ep-xxx.region.aws.neon.tech/attendance?schema=public&sslmode=require
# Vercel Postgres 示例：postgresql://default:xxx@xxx-pooler.xxx.postgres.vercel-storage.com/verceldb?sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/attendance?schema=public"
